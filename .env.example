BE:
# Server
PORT=3000


# Database
MONGODB_URI=mongodb+srv://your_super_secret_mongodb_uri_here


# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long_change_in_production
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_32_characters_long
JWT_REFRESH_EXPIRES_IN=7d


# Email (Google OAuth)
GOOGLE_MAILER_CLIENT_ID=123456789-abcdefghijklmnop.apps.googleusercontent.com
GOOGLE_MAILER_CLIENT_SECRET=GOCSPX-abcdefghijklmnop123456
GOOGLE_MAILER_REFRESH_TOKEN=1//abcdefghijklmnopqrstuvwxyz123456789
FROM_NAME=GZMart E-commerce
ADMIN_EMAIL_ADDRESS=admin@gzmart.com


# Google Maps API (for Geocoding)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here


# Frontend URL
FRONTEND_URL=http://localhost:5173


# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz123456


# GHN (Giao Hàng Nhanh) Shipping Integration
GHN_API_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=your_ghn_token_here
GHN_SHOP_ID=your_ghn_shop_id_here
GHN_FROM_DISTRICT_ID=1542
GHN_FROM_WARD_CODE=21211
GHN_SENDER_NAME=GZMart Shop
GHN_SENDER_PHONE=0901234567
GHN_SENDER_ADDRESS=123 Nguyen Thai Hoc, Phuong 14, Quan 10, TP.HCM
GHN_SERVICE_TYPE_ID=2
GHN_PAYMENT_TYPE_ID=1
GHN_REQUIRED_NOTE=KHONGCHOXEMHANG
GHN_WEBHOOK_URL=https://your-domain.com/api/ghn/webhook

# LiveKit (Live Stream)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
